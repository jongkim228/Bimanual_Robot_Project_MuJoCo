<mujoco model="fr3v2 scene">
  <compiler angle="radian" meshdir="assets"/>
  <option>
  </option>
  
  <statistic center="0.2 0 0.4" extent=".8"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
  </asset>

  <include file="fr3v2_left.xml"/>
  <include file="fr3v2_right.xml"/>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>
    <body name = "robot_table_left" pos = "-0.1 0.4 0">
      <geom type="box" size = "0.2 0.1 0.3" rgba = "0.1 0.1 0.1 1"/>
    </body>
    <body name = "robot_table_right" pos = "-0.1 0 0">
      <geom type="box" size = "0.2 0.1 0.3" rgba = "0.1 0.1 0.1 1"/>
    </body>

    <body name = "target_table" pos = "0.4 0.2 0">
      <geom type="box" size = "0.2 0.4 0.3" rgba = "0.1 0.1 0.1 1"/>
    </body>

    <body name = "target_box1" pos = "0.4 0 0.4">
    <freejoint/>
      <geom type="box" size = "0.03 0.03 0.03" friction="1 0.01 0.01" rgba = "1 1 1 1"/>
    </body>

    <body name = "target_box2" pos = "0.4 0.4 0.4">
    <freejoint/>
      <geom type="box" size = "0.03 0.03 0.03" friction="1 0.01 0.01" rgba = "1 1 1 1"/>
    </body>



  </worldbody>

  <contact>
    <exclude body1="fr3v2_right_link8" body2="ff_base"/>
    <exclude body1="fr3v2_right_link8" body2="mf_base"/>
    <exclude body1="fr3v2_right_link8" body2="rf_base"/>
    <exclude body1="fr3v2_right_link8" body2="th_base"/>
    <exclude body1="fr3v2_right_link8" body2="th_proximal"/>

    <exclude body1="fr3v2_left_link8" body2="link_0_0"/>
    <exclude body1="fr3v2_left_link8" body2="link_1_0"/>
    <exclude body1="fr3v2_left_link8" body2="link_2_0"/>
    <exclude body1="fr3v2_left_link8" body2="link_3_0"/>
    <exclude body1="fr3v2_left_link8" body2="link_4_0"/>
    <exclude body1="fr3v2_left_link8" body2="link_5_0"/>
    <exclude body1="fr3v2_left_link8" body2="link_6_0"/>
    <exclude body1="fr3v2_left_link8" body2="link_7_0"/>
    <exclude body1="fr3v2_left_link8" body2="link_8_0"/>
  </contact>

</mujoco>